<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══ Header ═══ -->
        <LinearLayout
            android:id="@+id/header_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_accent"
            android:padding="20dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ TurboVec Explorer"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Quantized vector search · 2 / 3 / 4 / 8-bit · Stable external IDs"
                android:textColor="#B0B8D8"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ═══ Config Panel ═══ -->
        <LinearLayout
            android:id="@+id/config_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIGURATION"
                android:textColor="#6C7AE0"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <!-- Dimension row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dimension"
                    android:textColor="#C8CCEE"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/et_dim"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="384"
                    android:inputType="number"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2A2E4A"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Bit-width row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bit Width"
                    android:textColor="#C8CCEE"
                    android:textSize="13sp" />

                <RadioGroup
                    android:id="@+id/rg_bitwidth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton android:id="@+id/rb_2bit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textColor="#C8CCEE"
                        android:textSize="13sp"
                        android:buttonTint="#6C7AE0" />
                    <RadioButton android:id="@+id/rb_3bit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textColor="#C8CCEE"
                        android:textSize="13sp"
                        android:buttonTint="#6C7AE0" />
                    <RadioButton android:id="@+id/rb_4bit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4"
                        android:textColor="#C8CCEE"
                        android:textSize="13sp"
                        android:buttonTint="#6C7AE0"
                        android:checked="true" />
                    <RadioButton android:id="@+id/rb_8bit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8"
                        android:textColor="#C8CCEE"
                        android:textSize="13sp"
                        android:buttonTint="#6C7AE0" />
                </RadioGroup>
            </LinearLayout>

            <!-- File path row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Index File Path"
                android:textColor="#C8CCEE"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_filepath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="(set automatically to app files dir)"
                android:textColor="#FFFFFF"
                android:textColorHint="#555E88"
                android:backgroundTint="#2A2E4A"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="11sp"
                android:singleLine="true" />
        </LinearLayout>

        <!-- ═══ Action Buttons Row 1 ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_create"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Create Index"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4C5FD4" />

            <Button
                android:id="@+id/btn_load"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Load Index"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1F6B8A" />
        </LinearLayout>

        <!-- ═══ Action Buttons Row 2 ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_insert"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Insert Vectors"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1B7F5E" />

            <Button
                android:id="@+id/btn_search"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Search Top-K"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#6C2DB0" />
        </LinearLayout>

        <!-- ═══ Action Buttons Row 3 ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Delete IDs"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#8B2020" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Save Index"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5C4A1E" />
        </LinearLayout>

        <!-- ═══ Search Results Card ═══ -->
        <LinearLayout
            android:id="@+id/results_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SEARCH RESULTS"
                    android:textColor="#6C7AE0"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <TextView
                    android:id="@+id/tv_result_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 results"
                    android:textColor="#A0A8D0"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/results_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- ═══ Console ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CONSOLE"
                    android:textColor="#6C7AE0"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <Button
                    android:id="@+id/btn_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="Clear"
                    android:textAllCaps="false"
                    android:textSize="11sp"
                    android:textColor="#A0A8D0"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:backgroundTint="#1A1E30" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/console_scroll"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/tv_console"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#A9B2C3"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"
                    android:text="[System] TurboVec Explorer ready.\n[System] Configure dimension and bit-width, then Create or Load an index.\n" />
            </ScrollView>
        </LinearLayout>

        <!-- Bottom padding -->
        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
